# 📰 NewsPulse 环境配置示例
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# 新闻 API 密钥
# NEWSAPI_KEY=your_newsapi_key_here
# CRYPTO_COMPARE_API_KEY=your_api_key_here

# RSS 订阅源 (可选，自定义添加)
# RSS_FEEDS=https://example.com/rss1.xml,https://example.com/rss2.xml

# 情绪分析设置
SENTIMENT_LANGUAGE=zh,en
SENTIMENT_THRESHOLD=0.3

# 缓存设置 (秒)
CACHE_TTL=300

# 每次获取新闻数量
NEWS_LIMIT=20

# 调试模式
DEBUG=false
